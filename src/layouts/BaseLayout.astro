---
import Header from "@components/Header.astro";
import {
  DEFAULT_SITE_DESCRIPTION,
  DEFAULT_SOCIAL_IMAGE,
  DEFAULT_SOCIAL_IMAGE_ALT,
  DEFAULT_SOCIAL_IMAGE_HEIGHT,
  DEFAULT_SOCIAL_IMAGE_WIDTH,
  SITE_NAME,
} from "@lib/seo";
import "@styles/global.css";

type Props = {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  canonical?: string;
  noindex?: boolean;
  type?: "website" | "article" | "profile";
  publishedAt?: Date;
  updatedAt?: Date;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
};

const {
  title = SITE_NAME,
  description = DEFAULT_SITE_DESCRIPTION,
  image,
  imageAlt,
  imageWidth,
  imageHeight,
  canonical: canonicalOverride,
  noindex = false,
  type = "website",
  publishedAt,
  updatedAt,
  structuredData,
} = Astro.props;

const brandedTitle = `${title} - ${SITE_NAME}`;
const pageTitle = title.includes(SITE_NAME) || brandedTitle.length > 60 ? title : brandedTitle;
const seoDescription = description || DEFAULT_SITE_DESCRIPTION;
const canonical = new URL(canonicalOverride ?? Astro.url.pathname, Astro.site).toString();
const effectiveImage = image || DEFAULT_SOCIAL_IMAGE;
const imageUrl = effectiveImage
  ? effectiveImage.startsWith("http")
    ? effectiveImage
    : new URL(effectiveImage, Astro.site).toString()
  : undefined;
const effectiveImageAlt = imageAlt || DEFAULT_SOCIAL_IMAGE_ALT;
const effectiveImageWidth = image ? imageWidth : (imageWidth || DEFAULT_SOCIAL_IMAGE_WIDTH);
const effectiveImageHeight = image ? imageHeight : (imageHeight || DEFAULT_SOCIAL_IMAGE_HEIGHT);
const isArticle = type === "article";
const publishedIso = isArticle ? publishedAt?.toISOString() : undefined;
const updatedIso = isArticle ? updatedAt?.toISOString() : undefined;
const schemas = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const enablePlausible = import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      (() => {
        const storageKey = "hoyelam-theme";
        const root = document.documentElement;
        const stored = (() => {
          try {
            return window.localStorage.getItem(storageKey);
          } catch {
            return null;
          }
        })();
        const systemTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
        const theme = stored === "light" || stored === "dark" ? stored : systemTheme;

        root.dataset.theme = theme;
        root.style.colorScheme = theme;
      })();
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={seoDescription} />
    <meta name="author" content={SITE_NAME} />
    {noindex ? <meta name="robots" content="noindex" /> : null}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="canonical" href={canonical} />
    <link rel="author" href="/about/" />
    <link rel="alternate" type="application/rss+xml" href="/rss.xml" title={SITE_NAME} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={effectiveImageAlt} />
    {effectiveImageWidth ? <meta property="og:image:width" content={String(effectiveImageWidth)} /> : null}
    {effectiveImageHeight ? <meta property="og:image:height" content={String(effectiveImageHeight)} /> : null}
    {publishedIso ? <meta property="article:published_time" content={publishedIso} /> : null}
    {updatedIso ? <meta property="article:modified_time" content={updatedIso} /> : null}
    {publishedIso || updatedIso ? <meta property="article:author" content={SITE_NAME} /> : null}
    <meta name="twitter:card" content={imageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={seoDescription} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={effectiveImageAlt} />
    {schemas.map((schema) => <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />)}
    {
      enablePlausible ? (
        <script is:inline defer data-domain="hoyelam.com" src="https://plausible.io/js/plausible.js" />
      ) : null
    }
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="site-shell">
      <Header pathname={Astro.url.pathname} />
      <slot />
      <footer class="site-footer">
        <span>© {new Date().getFullYear()} Hoye Lam.</span>
        <nav class="footer-links" aria-label="Footer links">
          <a href="/rss.xml">RSS</a>
          <a href="https://github.com/hoyelam" target="_blank" rel="noreferrer">GitHub</a>
          <a href="https://twitter.com/hoyelam" target="_blank" rel="noreferrer">Twitter</a>
          <a href="https://www.instagram.com/hoyelam/" target="_blank" rel="noreferrer">Instagram</a>
        </nav>
      </footer>
    </div>
    <script is:inline>
      (() => {
        const storageKey = "hoyelam-theme";
        const root = document.documentElement;
        const toggle = document.querySelector("[data-theme-toggle]");
        const media = window.matchMedia("(prefers-color-scheme: dark)");

        const storedTheme = () => {
          try {
            return window.localStorage.getItem(storageKey);
          } catch {
            return null;
          }
        };

        const systemTheme = () => (media.matches ? "dark" : "light");

        const updateToggle = (theme) => {
          if (!toggle) return;
          const nextTheme = theme === "dark" ? "light" : "dark";
          const label = `Switch to ${nextTheme} mode`;
          toggle.setAttribute("aria-label", label);
          toggle.setAttribute("title", label);
        };

        const setTheme = (theme, persist = true) => {
          root.dataset.theme = theme;
          root.style.colorScheme = theme;

          if (persist) {
            try {
              window.localStorage.setItem(storageKey, theme);
            } catch {
              // Theme still changes for the current session when storage is unavailable.
            }
          }

          updateToggle(theme);
        };

        updateToggle(root.dataset.theme || systemTheme());

        toggle?.addEventListener("click", () => {
          const currentTheme = root.dataset.theme || systemTheme();
          setTheme(currentTheme === "dark" ? "light" : "dark");
        });

        media.addEventListener("change", () => {
          if (!storedTheme()) setTheme(systemTheme(), false);
        });
      })();
    </script>
  </body>
</html>

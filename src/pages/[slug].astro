---
import { render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getPages, getPosts } from "../lib/content";
import {
  DEFAULT_SOCIAL_IMAGE,
  DEFAULT_SOCIAL_IMAGE_HEIGHT,
  DEFAULT_SOCIAL_IMAGE_WIDTH,
  getEntryExcerpt,
  getEntryImage,
  getEntryImageAlt,
  getSeoDescription,
  SITE_NAME,
  toAbsoluteUrl,
} from "../lib/seo";
import { formatDate, formatRelativeDate } from "../lib/tags";

export async function getStaticPaths() {
  const posts = await getPosts();
  const pages = await getPages();

  return [
    ...posts.map((entry) => ({
      params: { slug: entry.id },
      props: { entry, kind: "post" },
    })),
    ...pages
      .filter((entry) => entry.id !== "home")
      .map((entry) => ({
        params: { slug: entry.id },
        props: { entry, kind: "page" },
      })),
  ];
}

const { entry, kind } = Astro.props;
const { Content } = await render(entry);
const title = entry.data.title;
const description =
  kind === "post"
    ? getEntryExcerpt(entry, 160) || getSeoDescription(entry)
    : getSeoDescription(entry);
const image = getEntryImage(entry);
const imageAlt = getEntryImageAlt(entry);
const canonical = new URL(`/${entry.id}/`, Astro.site).toString();
const absoluteImage = toAbsoluteUrl(image, Astro.site);
const personId = new URL("/#person", Astro.site).toString();
const isDefaultImage = image === DEFAULT_SOCIAL_IMAGE;
const structuredData =
  kind === "post"
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title,
        description,
        url: canonical,
        mainEntityOfPage: canonical,
        datePublished: entry.data.publishedAt?.toISOString(),
        dateModified: (entry.data.updatedAt || entry.data.publishedAt)?.toISOString(),
        image: absoluteImage,
        author: {
          "@type": "Person",
          "@id": personId,
          name: SITE_NAME,
          url: new URL("/", Astro.site).toString(),
        },
      }
    : {
        "@context": "https://schema.org",
        "@type": "WebPage",
        name: title,
        description,
        url: canonical,
        author: {
          "@type": "Person",
          "@id": personId,
          name: SITE_NAME,
        },
      };
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  imageWidth={isDefaultImage ? DEFAULT_SOCIAL_IMAGE_WIDTH : undefined}
  imageHeight={isDefaultImage ? DEFAULT_SOCIAL_IMAGE_HEIGHT : undefined}
  type={kind === "post" ? "article" : "website"}
  publishedAt={entry.data.publishedAt}
  updatedAt={entry.data.updatedAt}
  structuredData={structuredData}
>
  <main class="article">
    <header class="article-header">
      <h1>{title}</h1>
      {kind === "page" && description ? <p class="article-description">{description}</p> : null}
      {
        kind === "post" ? (
          <p class="post-meta">
            <time datetime={entry.data.publishedAt?.toISOString()}>
              {formatDate(entry.data.publishedAt)}
            </time>
            {entry.data.publishedAt ? (
              <>
                <span aria-hidden="true"> · </span>
                <span data-relative-date={entry.data.publishedAt.toISOString()}>
                  {formatRelativeDate(entry.data.publishedAt)}
                </span>
              </>
            ) : null}
          </p>
        ) : null
      }
    </header>
    <article class="article-content">
      <Content />
    </article>
  </main>
</BaseLayout>

---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getProjectSlug, projects } from "../../data/projects";
import { SITE_NAME, toAbsoluteUrl } from "../../lib/seo";

export function getStaticPaths() {
  const archivedProjects = projects.filter((project) => project.portfolioTier !== "featured");

  return archivedProjects.map((project) => ({
    params: { slug: getProjectSlug(project) },
    props: { project },
  }));
}

const { project } = Astro.props;
const images =
  project.images ??
  (project.thumbnail
    ? [{ src: project.thumbnail, alt: project.thumbnailAlt ?? `${project.name} preview` }]
    : []);
const canonical = new URL(`/portfolio/${getProjectSlug(project)}/`, Astro.site).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: project.name,
  description: project.description,
  url: canonical,
  image: toAbsoluteUrl(images[0]?.src, Astro.site),
  creator: {
    "@type": "Person",
    name: SITE_NAME,
    url: new URL("/", Astro.site).toString(),
  },
  sameAs: project.href,
};
---

<BaseLayout
  title={project.name}
  description={project.description}
  image={images[0]?.src}
  imageAlt={images[0]?.alt}
  structuredData={structuredData}
>
  <main class="article project-detail">
    <header class="article-header">
      <a class="project-back-link" href="/portfolio/">Portfolio</a>
      <h1>{project.name}</h1>
      <p class="article-description">{project.description}</p>
      <p class="post-meta">{project.period} · {project.role}</p>
    </header>
    <article class="article-content">
      {
        project.contribution ? (
          <p>{project.contribution}</p>
        ) : (
          <p>Archived project from my earlier portfolio.</p>
        )
      }
      {
        images.length ? (
          <div class="project-gallery">
            {images.map((image) => (
              <img src={image.src} alt={image.alt} loading="lazy" />
            ))}
          </div>
        ) : null
      }
    </article>
  </main>
</BaseLayout>

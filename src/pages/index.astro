---
import PostList from "@components/PostList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { projects } from "../data/projects";
import { getPosts } from "../lib/content";
import { HOME_SITE_DESCRIPTION, HOME_SITE_TITLE, SITE_NAME } from "../lib/seo";

const posts = (await getPosts()).slice(0, 6);
const currentProjects = projects.filter((project) => project.status === "Current");
const personId = new URL("/#person", Astro.site).toString();
const homeUrl = new URL("/", Astro.site).toString();
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": personId,
    name: SITE_NAME,
    alternateName: ["林浩意", "@hoyelam"],
    description: HOME_SITE_DESCRIPTION,
    url: homeUrl,
    image: new URL("/images/hoye-lam-x-avatar.jpg", Astro.site).toString(),
    jobTitle: "Senior Software Engineer",
    worksFor: {
      "@type": "Organization",
      name: "DeepL",
      url: "https://www.deepl.com/",
    },
    sameAs: [
      "https://github.com/hoyelam",
      "https://twitter.com/hoyelam",
      "https://www.instagram.com/hoyelam/",
    ],
    knowsAbout: [
      "iOS development",
      "macOS development",
      "Swift",
      "indie app development",
      "software products",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE_NAME,
    url: homeUrl,
    description: HOME_SITE_DESCRIPTION,
    author: { "@id": personId },
  },
];
---

<BaseLayout title={HOME_SITE_TITLE} description={HOME_SITE_DESCRIPTION} structuredData={structuredData}>
  <main>
    <section class="hero">
      <img
        class="hero-avatar"
        src="/images/hoye-lam-x-avatar.jpg"
        alt="Hoye Lam"
        width="400"
        height="400"
        decoding="async"
      />
      <h1>Hoye Lam</h1>
      <p class="hero-copy">
        I build useful software and write what I actually think. By day, I’m a senior software engineer at{" "}
        <a href="https://www.deepl.com/" target="_blank" rel="noreferrer">DeepL</a> who specializes in software
        for Apple platforms. Outside work, I build{" "}
        <a href="https://loudscript.app/" target="_blank" rel="noreferrer">LoudScript</a>,{" "}
        <a href="https://websave.app/" target="_blank" rel="noreferrer">Websave</a>, and{" "}
        <a href="https://thinkdrop.app/" target="_blank" rel="noreferrer">Thinkdrop 2</a>; co-founded{" "}
        <a href="https://waterfuze.com/" target="_blank" rel="noreferrer">Waterfuze</a>; and write candidly about
        software, products, work, family, and ambition.
      </p>
      <div class="actions">
        <a class="button primary" href="/portfolio/">View portfolio</a>
        <a class="button secondary" href="/writing/">Read writing</a>
      </div>
    </section>

    {
      posts.length ? (
        <section class="section">
          <div class="section-heading">
            <h2>Recent writing</h2>
            <a class="muted" href="/writing/">Archive</a>
          </div>
          <PostList posts={posts} />
        </section>
      ) : null
    }

    <section class="section">
      <div class="section-heading">
        <h2>Current projects</h2>
        <a class="muted" href="/portfolio/">All projects</a>
      </div>
      <div class="project-grid">
        {
          currentProjects.map((project) => (
            <article class="project-card">
              <div class="project-preview">
                {project.thumbnail ? (
                  <img
                    src={project.thumbnail}
                    alt={project.thumbnailAlt ?? `${project.name} preview`}
                    loading="lazy"
                  />
                ) : (
                  <div class="project-preview-fallback" aria-hidden="true">{project.name.slice(0, 2)}</div>
                )}
              </div>
              <div class="project-body">
                <div class="project-meta">{project.status} · {project.role}</div>
                <h3>
                  {project.href ? <a href={project.href}>{project.name}</a> : project.name}
                </h3>
                <p>{project.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

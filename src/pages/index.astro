---
import PostList from "@components/PostList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { projects } from "../data/projects";
import { getPosts } from "../lib/content";

const posts = (await getPosts()).slice(0, 6);
const currentProjects = projects.filter((project) => project.status === "Current");
---

<BaseLayout title="Hoye Lam" description="Portfolio, apps, writing, and notes by Hoye Lam.">
  <main>
    <section class="hero">
      <h1>Apps, software, and writing.</h1>
      <div class="hero-copy">
        <p>
          I build iOS, macOS, and web products. This site is the static home for
          my portfolio, project history, and occasional writing.
        </p>
        <div class="actions">
          <a class="button primary" href="/portfolio/">View portfolio</a>
          <a class="button secondary" href="/writing/">Read writing</a>
        </div>
      </div>
    </section>

    {
      posts.length ? (
        <section class="section">
          <div class="section-heading">
            <h2>Recent Writing</h2>
            <a class="muted" href="/writing/">Archive</a>
          </div>
          <PostList posts={posts} />
        </section>
      ) : null
    }

    <section class="section">
      <div class="section-heading">
        <h2>Current projects</h2>
        <a class="muted" href="/portfolio/">All projects</a>
      </div>
      <div class="project-grid">
        {
          currentProjects.map((project) => (
            <article class="project-card">
              <div class="project-preview">
                {project.thumbnail ? (
                  <img
                    src={project.thumbnail}
                    alt={project.thumbnailAlt ?? `${project.name} preview`}
                    loading="lazy"
                  />
                ) : (
                  <div class="project-preview-fallback" aria-hidden="true">{project.name.slice(0, 2)}</div>
                )}
              </div>
              <div class="project-body">
                <div class="project-meta">{project.status} · {project.role}</div>
                <h3>
                  {project.href ? <a href={project.href}>{project.name}</a> : project.name}
                </h3>
                <p>{project.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

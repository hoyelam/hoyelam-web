---
import PostList from "@components/PostList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { projects } from "../data/projects";
import { getPosts } from "../lib/content";

const posts = (await getPosts()).slice(0, 6);
const currentProjects = projects.filter((project) => project.status === "Current");
---

<BaseLayout title="Hoye Lam" description="Portfolio, apps, writing, and notes by Hoye Lam.">
  <main>
    <section class="hero">
      <img
        class="hero-avatar"
        src="/images/hoye-lam-x-avatar.jpg"
        alt="Hoye Lam"
      />
      <h1>Hoye Lam</h1>
      <p class="hero-copy">
        Senior Software Engineer at <a href="https://www.deepl.com/" target="_blank" rel="noreferrer">DeepL</a>{" "}
        specializing in iOS and macOS. Built{" "}
        <a href="https://loudscript.app/" target="_blank" rel="noreferrer">LoudScript</a>,{" "}
        <a href="https://websave.app/" target="_blank" rel="noreferrer">Websave</a>, and{" "}
        <a href="https://thinkdrop.app/" target="_blank" rel="noreferrer">Thinkdrop 2</a>. Co-founded{" "}
        <a href="https://waterfuze.com/" target="_blank" rel="noreferrer">Waterfuze</a>, previously led software
        at Somnox, and write about software, products, and life.
      </p>
      <div class="actions">
        <a class="button primary" href="/portfolio/">View portfolio</a>
        <a class="button secondary" href="/writing/">Read writing</a>
      </div>
    </section>

    {
      posts.length ? (
        <section class="section">
          <div class="section-heading">
            <h2>Recent Writing</h2>
            <a class="muted" href="/writing/">Archive</a>
          </div>
          <PostList posts={posts} />
        </section>
      ) : null
    }

    <section class="section">
      <div class="section-heading">
        <h2>Current projects</h2>
        <a class="muted" href="/portfolio/">All projects</a>
      </div>
      <div class="project-grid">
        {
          currentProjects.map((project) => (
            <article class="project-card">
              <div class="project-preview">
                {project.thumbnail ? (
                  <img
                    src={project.thumbnail}
                    alt={project.thumbnailAlt ?? `${project.name} preview`}
                    loading="lazy"
                  />
                ) : (
                  <div class="project-preview-fallback" aria-hidden="true">{project.name.slice(0, 2)}</div>
                )}
              </div>
              <div class="project-body">
                <div class="project-meta">{project.status} · {project.role}</div>
                <h3>
                  {project.href ? <a href={project.href}>{project.name}</a> : project.name}
                </h3>
                <p>{project.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

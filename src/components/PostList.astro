---
import { formatDate, formatRelativeDate } from "@lib/tags";
import { getEntryExcerpt } from "@lib/seo";

type Post = {
  id: string;
  body?: string;
  data: {
    title: string;
    description?: string;
    publishedAt?: Date;
  };
};

type Props = {
  posts: Post[];
  headingLevel?: "h2" | "h3";
};

const { posts, headingLevel = "h2" } = Astro.props;
const Heading = headingLevel;
---

<div class="post-list">
  {
    posts.map((post) => {
      const excerpt = getEntryExcerpt(post);

      return (
        <a class="post-row" href={`/${post.id}/`}>
          <div>
            <Heading>{post.data.title}</Heading>
            {excerpt && <p class="post-excerpt muted">{excerpt}</p>}
          </div>
          <span class="post-meta">
            <time
              datetime={post.data.publishedAt?.toISOString()}
              title={formatRelativeDate(post.data.publishedAt)}
            >
              {formatDate(post.data.publishedAt)}
            </time>
          </span>
        </a>
      );
    })
  }
</div>

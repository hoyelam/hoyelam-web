---
import { formatDate, formatRelativeDate } from "@lib/tags";
import { getEntryExcerpt } from "@lib/seo";

type Post = {
  id: string;
  body?: string;
  data: {
    title: string;
    description?: string;
    publishedAt?: Date;
  };
};

type Props = {
  posts: Post[];
  headingLevel?: "h2" | "h3";
};

const { posts, headingLevel = "h2" } = Astro.props;
const Heading = headingLevel;
---

<div class="post-list">
  {
    posts.map((post) => {
      const excerpt = getEntryExcerpt(post);

      return (
        <a class="post-row" href={`/${post.id}/`}>
          <div>
            <Heading>{post.data.title}</Heading>
            {excerpt && <p class="muted">{excerpt}</p>}
          </div>
          <span class="post-meta">
            <time datetime={post.data.publishedAt?.toISOString()}>
              {formatDate(post.data.publishedAt)}
            </time>
            {post.data.publishedAt ? (
              <>
                <span aria-hidden="true"> · </span>
                <span data-relative-date={post.data.publishedAt.toISOString()}>
                  {formatRelativeDate(post.data.publishedAt)}
                </span>
              </>
            ) : null}
          </span>
        </a>
      );
    })
  }
</div>

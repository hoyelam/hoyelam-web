---
import { projects } from "../data/projects";

const featured = projects.filter((project) => project.portfolioTier === "featured");
const past = projects.filter((project) => project.portfolioTier === "past");
const archive = projects.filter((project) => project.portfolioTier === "archive");

const fallback = (name: string) => name.slice(0, 2);
const isLinkableArchive = (project: (typeof projects)[number]) =>
  Boolean(project.href && project.status !== "Archived");
---

<section class="portfolio-section">
  <h2>Current Focus</h2>
  <div class="portfolio-featured-grid">
    {
      featured.map((project) => (
        <article class="portfolio-card">
          <div class="portfolio-card-media">
            {project.thumbnail ? (
              <img
                src={project.thumbnail}
                alt={project.thumbnailAlt ?? `${project.name} preview`}
                loading="lazy"
              />
            ) : (
              <div class="portfolio-card-fallback" aria-hidden="true">{fallback(project.name)}</div>
            )}
          </div>
          <div class="portfolio-card-body">
            <p class="portfolio-meta">{project.period} · {project.role}</p>
            <h3>
              {project.href ? (
                <a href={project.href} target="_blank" rel="noreferrer">{project.name}</a>
              ) : project.name}
            </h3>
            <p>{project.description}</p>
            {project.contribution ? <p class="portfolio-contribution">{project.contribution}</p> : null}
          </div>
        </article>
      ))
    }
  </div>
</section>

<section class="portfolio-section">
  <h2>Selected Past Work</h2>
  <div class="portfolio-past-grid">
    {
      past.map((project) => (
        <article class="portfolio-card portfolio-card-compact">
          <div class="portfolio-card-media">
            {project.thumbnail ? (
              <img
                src={project.thumbnail}
                alt={project.thumbnailAlt ?? `${project.name} preview`}
                loading="lazy"
              />
            ) : (
              <div class="portfolio-card-fallback" aria-hidden="true">{fallback(project.name)}</div>
            )}
          </div>
          <div class="portfolio-card-body">
            <p class="portfolio-meta">{project.period} · {project.role}</p>
            <h3>
              {project.href ? (
                <a href={project.href} target="_blank" rel="noreferrer">{project.name}</a>
              ) : project.name}
            </h3>
            <p>{project.description}</p>
            {project.contribution ? <p class="portfolio-contribution">{project.contribution}</p> : null}
          </div>
        </article>
      ))
    }
  </div>
</section>

<section class="portfolio-section">
  <h2>Archive</h2>
  <ul class="portfolio-archive">
    {
      archive.map((project) => (
        <li>
          <span>
            <strong>
              {isLinkableArchive(project) ? (
                <a href={project.href} target="_blank" rel="noreferrer">{project.name}</a>
              ) : project.name}
            </strong>
            <span>{project.description}</span>
          </span>
          <em>{project.period}</em>
        </li>
      ))
    }
  </ul>
</section>
